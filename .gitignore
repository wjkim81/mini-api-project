# Docker volumes (large, generated)
postgres_data/
vector_data/
redis_data/
EOF


# =============================================================================
# Additional Notes
# =============================================================================
# This .gitignore is designed for the PUBLIC repository (psychology-system)
# 
# Remember:
# - NEVER commit files from psychology-data/ (private markdown files)
# - NEVER commit .env with real API keys
# - NEVER commit vectordb/ (contains embeddings of private data)
# - NEVER commit logs (may contain query history)
# 
# If you accidentally commit private data:
# 1. git rm --cached <file>
# 2. Add to .gitignore
# 3. git commit -m "Remove private data"
# 4. Consider the data compromised - rotate API keys if exposed
# 
# For sensitive commits that were pushed:
# - Use git filter-branch or BFG Repo-Cleaner
# - Or create a fresh repository and copy only safe files